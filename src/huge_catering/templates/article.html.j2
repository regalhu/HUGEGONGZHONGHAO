<section style="font-size:16px;line-height:1.85;color:#2f343b;margin:0 auto;max-width:677px;">
  <p style="margin:0 0 18px;">{{ article.intro }}</p>

  <p style="margin:18px 0;padding:14px;border:1px dashed #c7c7cc;color:#6b7280;text-align:center;">
    [图片插入位]
  </p>

  {% for advice in article.advices %}
  <section style="margin:22px 0;padding:18px 18px 16px;border-left:5px solid #b42318;background:#fff7ed;">
    <p style="margin:0 0 8px;color:#b42318;font-size:18px;font-weight:700;">
      {{ "%02d"|format(advice.index) }} {{ advice.title }}
    </p>
    <p style="margin:0;color:#374151;">{{ advice.body }}</p>
  </section>
  {% endfor %}

  <section style="margin:28px 0 8px;padding:18px;background:#1f2933;color:#fff;">
    <p style="margin:0;">{{ article.conclusion }}</p>
  </section>

  {% if article.trend_sources %}
  <section style="margin:18px 0;padding:14px;background:#f5f5f7;color:#4b5563;font-size:13px;line-height:1.7;">
    <p style="margin:0 0 6px;font-weight:700;color:#374151;">公开数据源参考：</p>
    {% for source in article.trend_sources[:3] %}
      <p style="margin:0;">{{ loop.index }}. {{ source }}</p>
    {% endfor %}
  </section>
  {% endif %}

  <p style="margin:18px 0 0;color:#6b7280;font-size:14px;">
    栏目：{{ brand_name }} · {{ article.publish_date.strftime("%Y-%m-%d") }}
  </p>
</section>
